{
    "name": "proxyscrape-proxy-checker",
    "version": "1.1.0",
    "main": "./out/main/index.js",
    "license": "MIT",
    "author": {
        "name": "ProxyScrape",
        "email": "support@proxyscrape.com",
        "url": "https://proxyscrape.com/home"
    },
    "keywords": [
        "ProxyScrape",
        "proxy",
        "checker"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/ProxyScrape/proxy-checker"
    },
    "bugs": {
        "url": "https://github.com/ProxyScrape/proxy-checker/issues"
    },
    "homepage": "https://proxyscrape.com/proxy-checker",
    "scripts": {
        "dev": "electron-vite dev",
        "build": "electron-vite build",
        "start": "electron-vite preview",
        "package": "npm run build && electron-builder --win",
        "package-mac": "npm run build && electron-builder --mac",
        "package-linux": "npm run build && electron-builder --linux",
        "package-all": "npm run build && electron-builder --mac --win --linux",
        "publish": "npm run build && electron-builder --win --publish always",
        "publish-mac": "npm run build && electron-builder --mac --publish always",
        "publish-linux": "npm run build && electron-builder --linux --publish always",
        "publish-all": "npm run build && electron-builder --mac --win --linux --publish always",
        "postinstall": "electron-builder install-app-deps"
    },
    "devDependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@fontsource/montserrat": "^5.2.8",
        "@mui/material": "^9.0.0",
        "@vitejs/plugin-react": "^4.3.0",
        "axios": "^1.2.0",
        "electron": "^41.1.0",
        "electron-builder": "^26.8.2",
        "electron-updater": "^6.3.0",
        "electron-vite": "^3.1.0",
        "fast-sort": "^3.4.0",
        "ip": "^2.0.1",
        "maxmind": "^4.3.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-markdown": "^9.0.0",
        "react-redux": "^8.0.2",
        "redux": "^4.2.0",
        "redux-thunk": "^2.4.1",
        "reselect": "^4.1.6",
        "socks-proxy-agent": "^8.0.5",
        "uuid": "^9.0.0",
        "vite-plugin-electron-renderer": "^0.14.6"
    },
    "build": {
        "mac": {
            "icon": "./public/icons/icon.icns",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "category": "public.app-category.utilities",
            "artifactName": "${name}-v${version}-${arch}-${os}.${ext}"
        },
        "win": {
            "icon": "./public/icons/icon.ico",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                },
                {
                    "target": "portable",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "artifactName": "${name}-v${version}-${arch}-${os}-installer.${ext}"
        },
        "linux": {
            "icon": "./public/icons/icon.png",
            "target": [
                {
                    "target": "AppImage",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "category": "Network",
            "artifactName": "${name}-v${version}-${arch}-${os}.${ext}"
        },
        "publish": [
            {
                "provider": "github",
                "owner": "ProxyScrape",
                "repo": "proxyscrape-proxy-checker",
                "private": false
            }
        ],
        "productName": "ProxyScrape Proxy Checker",
        "copyright": "ProxyScrape",
        "extraResources": [
            "./files/**"
        ],
        "portable": {
            "artifactName": "${name}-v${version}-${arch}-${os}-portable.${ext}"
        },
        "nsis": {
            "oneClick": false,
            "perMachine": true,
            "allowToChangeInstallationDirectory": true,
            "differentialPackage": true
        }
    },
    "dependencies": {
        "@posthog/react": "^1.9.0",
        "posthog-js": "^1.367.0"
    }
}
